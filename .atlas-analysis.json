  "keyFeatures": [
    "Isolated control plane with dedicated API server per virtual cluster",
    "Multiple deployment architectures: shared nodes, dedicated nodes, private nodes, and standalone",
    "Bidirectional resource syncing between virtual and host clusters",
    "Sleep mode for pausing inactive virtual clusters",
    "High availability with etcd and leader election",
    "Hybrid scheduling for AI/ML workloads",
    "Auto nodes with Karpenter-powered dynamic autoscaling",
    "Snapshot and restore capabilities",
    "Native integrations with cert-manager, external-secrets, and Istio",
    "CLI tool for managing virtual cluster lifecycle"
  ],
  "publicApiSurface": [
    "vcluster create - Create a new virtual cluster",
    "vcluster connect - Connect to a virtual cluster",
    "vcluster list - List all virtual clusters",
    "vcluster delete - Delete a virtual cluster",
    "vcluster pause - Pause a virtual cluster",
    "vcluster resume - Resume a paused virtual cluster",
    "vcluster upgrade - Upgrade a virtual cluster",
    "vcluster snapshot - Manage virtual cluster snapshots",
    "vcluster restore - Restore from a snapshot",
    "vcluster node - Manage virtual cluster nodes",
    "vcluster token - Manage authentication tokens",
    "vcluster debug - Debug virtual cluster issues",
    "Helm Chart - chart/values.yaml configuration",
    "sync.toHost - Resources synced from virtual to host cluster",
    "sync.fromHost - Resources synced from host to virtual cluster",
    "controlPlane - Control plane configuration options",
    "privateNodes - Private nodes configuration",
    "autoNodes - Auto nodes configuration"
  ]
}
